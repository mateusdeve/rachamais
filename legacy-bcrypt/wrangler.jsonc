{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rachamais-legacy-bcrypt",
  "main": "src/index.js",
  "compatibility_date": "2025-11-02",
  "compatibility_flags": ["nodejs_compat"],
  // No routes and no workers.dev URL: this worker is only reachable through the
  // LEGACY_BCRYPT service binding on rachamais-api.
  "workers_dev": false,
  "observability": {
    "enabled": true
  }
}
